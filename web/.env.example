# =============================================================================
# Doc2Task - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://doc2task:doc2task@localhost:5432/doc2task"

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# The base URL of the application (used for callbacks and redirects)
NEXTAUTH_URL="http://localhost:3000"

# Secret key for JWT signing and encryption (min 32 characters)
# Also used as the encryption secret for API key storage (AES-256-GCM)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV="development"
