# ── Shared / scripts ─────────────────────────────────────────────────────────

# LLM model to use (default: deepseek-chat)
MODEL=deepseek-chat

# DeepSeek / OpenAI-compatible API key (used by scripts/main.py)
DICKSICK_API_KEY=

# ── Plane MCP ────────────────────────────────────────────────────────────────
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=
PLANE_BASE_URL=https://plane.example.com

# ── web/ — Next.js application ───────────────────────────────────────────────
# Copy this block into web/.env as well

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/doc2task

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Encryption key for API key vault — 32-byte hex — generate with: openssl rand -hex 32
ENCRYPTION_KEY=
